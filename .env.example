# Copy to `.env.local` for local dev, and add the same value as a GitHub
# Actions secret (Settings → Secrets and variables → Actions) for deploys.
#
# Web3Forms access key — powers the contact form (components/site/contact-form.tsx).
# Get one (free) at https://web3forms.com. This is a PUBLISHABLE key: it ships to
# the browser by design, so the NEXT_PUBLIC_ prefix is intentional.
NEXT_PUBLIC_WEB3FORMS_ACCESS_KEY=
